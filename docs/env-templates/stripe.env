# Stripe (ecommerce). Get keys from https://dashboard.stripe.com/apikeys
# Webhook secret: create endpoint in Stripe Workbench (https://dashboard.stripe.com/webhooks). Add these to .env.local when the tenant needs ecommerce. Never commit real keys.

STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
